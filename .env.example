# App Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/runcoach

# Redis
REDIS_URL=redis://localhost:6379

# Strava OAuth
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=your-random-verify-token

# Security
# Generate with: openssl rand -hex 32
JWT_SECRET=
# AES-256 key to encrypt Strava tokens (must be exactly 64 hex chars / 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
